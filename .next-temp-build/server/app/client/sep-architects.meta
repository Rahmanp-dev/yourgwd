    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/client/layout,_N_T_/client/sep-architects/layout,_N_T_/client/sep-architects/page,_N_T_/client/sep-architects"
  },
  "segmentPaths": [
    "/_tree",
