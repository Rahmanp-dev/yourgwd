{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/client/layout,_N_T_/client/raja-architects/layout,_N_T_/client/raja-architects/page,_N_T_/client/raja-architects"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/client/raja-architects/__PAGE__",
    "/client/raja-architects",
    "/client",
    "/_index",
    "/_head"
  ]
}